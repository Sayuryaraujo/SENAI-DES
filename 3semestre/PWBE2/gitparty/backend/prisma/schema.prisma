generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuarios {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  senha         String
  data_cadastro DateTime @default(now())

  incricoes Incricoes[]
}

model Eventos {
  id                Int           @id @default(autoincrement())
  titulo            String
  descricao         String
  data_evento       DateTime
  local             String
  capacidade_maxima Int
  status            StatusEventos @default(ATIVO)

  imagens   Imagem[]

  incricoes Incricoes[]
}

enum StatusEventos {
  ATIVO
  CANCELADO
  ENCERRADO
}

model Incricoes {
  id            Int            @id @default(autoincrement())
  data_incricao DateTime       @default(now())
  status        StatusIncricao @default(CONFIRMADA)

  eventos    Eventos  @relation(fields: [eventosId], references: [id])
  eventosId  Int
  usuarios   Usuarios @relation(fields: [usuariosId], references: [id])
  usuariosId Int
}

enum StatusIncricao {
  CONFIRMADA
  LISTA_ESPERA
  CANCELADA
}

model Imagem {
  id            Int      @id @default(autoincrement())
  nomeOriginal  String
  nomeArquivo   String
  mimeType      String
  path          String
  data          DateTime @default(now())

  eventoId Int
  evento   Eventos @relation(fields: [eventoId], references: [id])
}